// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  SCHOOL_ADMIN
  ADMIN
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SchoolStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student     Student?
  school      School?
  notifications Notification[]
  auditLogs   AuditLog[]

  @@map("users")
}

model Student {
  id            String   @id @default(cuid())
  userId        String   @unique
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  phone         String?
  address       String?
  mathGrade     Float
  biologyGrade  Float
  englishGrade  Float
  interests     String[] // JSON array of interests
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  documents    Document[]

  @@map("students")
}

model School {
  id               String       @id @default(cuid())
  userId           String       @unique
  name             String
  description      String?
  address          String
  phone            String
  email            String
  website          String?
  latitude         Float
  longitude        Float
  verificationCode String?
  isVerified       Boolean      @default(false)
  status           SchoolStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  programs Program[]

  @@map("schools")
}

model Program {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  category    String   // e.g., "engineering", "health"
  duration    Int      // in months
  capacity    Int
  deadline    DateTime
  requirements String? // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("programs")
}

model Application {
  id         String            @id @default(cuid())
  studentId  String
  programId  String
  status     ApplicationStatus @default(PENDING)
  appliedAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([studentId, programId])
  @@map("applications")
}

model Document {
  id         String   @id @default(cuid())
  studentId  String
  name       String
  url        String   // file URL or path
  type       String   // e.g., "pdf"
  uploadedAt DateTime @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?  // JSON string
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}